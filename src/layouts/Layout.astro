---
interface Props {
  title?: string;
  description?: string;
  canonical?: string;
  ogImage?: string;
}

const {
  title = 'COMBRIDGE | Taller de liderazgo y gestión de proyectos — Comtraining',
  description = 'Construye un puente de 14 metros con tu equipo en 90 minutos. Taller experiencial de colaboración, liderazgo y gestión de proyectos. In-company en Chile.',
  canonical = 'https://combridge.comtraining.cl',
  ogImage = '/images/puente-terminado-grupo.jpg',
} = Astro.props;
---

<!doctype html>
<html lang="es" hreflang="es-CL">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="generator" content={Astro.generator} />

    <title>{title}</title>
    <meta name="description" content={description} />
    <link rel="canonical" href={canonical} />
    <link hreflang="es-CL" href={canonical} rel="alternate" />

    <meta property="og:type" content="website" />
    <meta property="og:url" content={canonical} />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:image" content={`${canonical}${ogImage}`} />
    <meta property="og:image:width" content="1200" />
    <meta property="og:image:height" content="630" />
    <meta property="og:locale" content="es_CL" />
    <meta property="og:site_name" content="Comtraining" />

    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={`${canonical}${ogImage}`} />

    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />

    <!-- Google Analytics 4 — reemplazar G-XXXXXXXXXX con el ID real -->
    <script async src="https://www.googletagmanager.com/gtag/js?id=G-XXXXXXXXXX"></script>
    <script is:inline>
      window.dataLayer = window.dataLayer || [];
      function gtag(){dataLayer.push(arguments);}
      gtag('js', new Date());
      gtag('config', 'G-XXXXXXXXXX', { anonymize_ip: true });
    </script>

    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      rel="preload"
      as="style"
      href="https://fonts.googleapis.com/css2?family=Manrope:wght@400;500;600;700;800&family=Sora:wght@400;600;700;800&display=swap"
    />
    <link
      href="https://fonts.googleapis.com/css2?family=Manrope:wght@400;500;600;700;800&family=Sora:wght@400;600;700;800&display=swap"
      rel="stylesheet"
    />

    <script type="application/ld+json">
      {
        "@context": "https://schema.org",
        "@type": "Course",
        "name": "COMBRIDGE",
        "description": "Taller experiencial en el que equipos corporativos construyen un puente de 14 metros con 9.000 piezas en 90 minutos para desarrollar liderazgo, colaboración y gestión de proyectos.",
        "url": "https://combridge.comtraining.cl",
        "provider": {
          "@type": "Organization",
          "name": "Comtraining",
          "url": "https://comtraining.cl"
        },
        "educationalLevel": "Professional",
        "inLanguage": "es-CL",
        "courseMode": "in-person",
        "offers": {
          "@type": "Offer",
          "availability": "https://schema.org/InStock",
          "category": "In-company"
        },
        "instructor": {
          "@type": "Person",
          "name": "Francisco Vallés",
          "jobTitle": "Consultor y Coach Senior"
        }
      }
    </script>
  </head>
  <body>
    <a class="skip-link" href="#contenido">Saltar al contenido</a>
    <main id="contenido">
      <slot />
    </main>
    <script is:inline>
      // Auto-track any click on elements with data-event
      document.addEventListener('click', (e) => {
        const target = e.target instanceof Element ? e.target.closest('[data-event]') : null;
        if (!target) return;
        const name = target.getAttribute('data-event');
        if (typeof window.gtag === 'function') {
          window.gtag('event', name, { event_category: 'cta' });
        }
      });
    </script>
  </body>
</html>

<style is:global>
  @import '../styles/global.css';

  :root {
    --color-brand: #14324a;
    --color-brand-deep: #0b1c2d;
    --color-accent: #d96d3f;
    --color-accent-soft: #f1bb9f;
    --color-text: #102131;
    --color-text-soft: #5b6b79;
    --color-line: rgba(16, 33, 49, 0.12);
    --color-bg: #f3efe8;
    --color-surface: #fbf8f3;
    --color-surface-strong: #fffdf9;
    --font-sans: 'Manrope', ui-sans-serif, system-ui, sans-serif;
    --font-display: 'Sora', var(--font-sans);
    --container: min(1120px, calc(100vw - 2rem));
    --container-wide: min(1280px, calc(100vw - 2rem));
    --shadow-soft: 0 18px 50px rgba(8, 20, 32, 0.08);
    --shadow-strong: 0 24px 80px rgba(8, 20, 32, 0.18);
    --radius-sm: 18px;
    --radius-md: 28px;
    --radius-lg: 40px;
  }

  * {
    box-sizing: border-box;
  }

  html {
    font-family: var(--font-sans);
    color: var(--color-text);
    background:
      radial-gradient(circle at top left, rgba(217, 109, 63, 0.08), transparent 32%),
      linear-gradient(180deg, #f7f3ec 0%, #f3efe8 100%);
    scroll-behavior: smooth;
    overflow-x: hidden;
  }

  body {
    min-height: 100vh;
    margin: 0;
    background: transparent;
    overflow-x: hidden;
  }

  img {
    max-width: 100%;
  }

  a {
    color: inherit;
    -webkit-tap-highlight-color: rgba(217, 109, 63, 0.16);
  }

  a:focus-visible,
  button:focus-visible,
  summary:focus-visible {
    outline: 2px solid rgba(217, 109, 63, 0.9);
    outline-offset: 3px;
  }

  ::selection {
    background: rgba(217, 109, 63, 0.22);
  }

  .shell {
    width: var(--container);
    margin: 0 auto;
  }

  .shell-wide {
    width: var(--container-wide);
    margin: 0 auto;
  }

  .section {
    padding: 6rem 0;
    position: relative;
  }

  .section-intro {
    max-width: 720px;
    margin-bottom: 2.75rem;
  }

  .eyebrow {
    display: inline-flex;
    align-items: center;
    gap: 0.6rem;
    margin-bottom: 1rem;
    font-size: 0.78rem;
    font-weight: 800;
    letter-spacing: 0.16em;
    text-transform: uppercase;
    color: var(--color-accent);
  }

  .eyebrow::before {
    content: '';
    width: 2.5rem;
    height: 1px;
    background: currentColor;
    opacity: 0.6;
  }

  .section-title {
    margin: 0;
    font-family: var(--font-display);
    font-size: clamp(2rem, 4vw, 3.6rem);
    line-height: 1.05;
    letter-spacing: -0.04em;
    text-wrap: balance;
  }

  .section-copy {
    margin: 1rem 0 0;
    max-width: 62ch;
    font-size: 1.02rem;
    line-height: 1.75;
    color: var(--color-text-soft);
  }

  .button-row {
    display: flex;
    flex-wrap: wrap;
    gap: 0.9rem;
  }

  .button-primary,
  .button-secondary,
  .button-ghost {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    min-height: 3.5rem;
    padding: 0.95rem 1.45rem;
    border-radius: 999px;
    font-size: 0.96rem;
    font-weight: 700;
    text-decoration: none;
    touch-action: manipulation;
    transition:
      transform 0.25s ease,
      background-color 0.25s ease,
      border-color 0.25s ease,
      color 0.25s ease,
      box-shadow 0.25s ease;
  }

  .button-primary {
    background: var(--color-accent);
    color: #fff8f4;
    box-shadow: 0 12px 30px rgba(217, 109, 63, 0.28);
  }

  .button-primary:hover,
  .button-primary:focus-visible {
    transform: translateY(-2px);
    background: #c85d31;
  }

  .button-secondary {
    border: 1px solid rgba(255, 255, 255, 0.24);
    color: #fff;
    background: rgba(255, 255, 255, 0.08);
    backdrop-filter: blur(12px);
  }

  .button-secondary:hover,
  .button-secondary:focus-visible {
    transform: translateY(-2px);
    background: rgba(255, 255, 255, 0.16);
  }

  .button-ghost {
    border: 1px solid var(--color-line);
    color: var(--color-text);
    background: rgba(255, 255, 255, 0.72);
  }

  .button-ghost:hover,
  .button-ghost:focus-visible {
    transform: translateY(-2px);
    border-color: rgba(16, 33, 49, 0.22);
    background: #ffffff;
  }

  .reveal {
    opacity: 0;
    transform: translateY(28px);
    transition: opacity 0.7s ease, transform 0.7s ease;
  }

  .reveal.visible {
    opacity: 1;
    transform: translateY(0);
  }

  .skip-link {
    position: fixed;
    top: 1rem;
    left: 1rem;
    z-index: 100;
    padding: 0.85rem 1rem;
    border-radius: 999px;
    background: var(--color-brand-deep);
    color: #fff;
    text-decoration: none;
    transform: translateY(-140%);
    transition: transform 0.2s ease;
  }

  .skip-link:focus-visible {
    transform: translateY(0);
  }

  #experiencia,
  #aprendizajes,
  #para-quien,
  #industrias,
  #profesor,
  #faq,
  #agendar {
    scroll-margin-top: 6.75rem;
  }

  #aprendizajes {
    scroll-margin-top: 8.5rem;
  }

  @media (max-width: 960px) {
    .section {
      padding: 5rem 0;
    }
  }

  @media (max-width: 720px) {
    :root {
      --container: min(1120px, calc(100vw - 1.25rem));
      --container-wide: min(1280px, calc(100vw - 1.25rem));
    }

    .section {
      padding: 3.75rem 0;
    }

    .section-intro {
      margin-bottom: 1.6rem;
    }

    .button-row {
      flex-direction: column;
    }

    .button-primary,
    .button-secondary,
    .button-ghost {
      width: 100%;
    }

    .section-copy {
      font-size: 0.98rem;
      line-height: 1.7;
    }
  }

  @media (prefers-reduced-motion: reduce) {
    html {
      scroll-behavior: auto;
    }

    *,
    *::before,
    *::after {
      animation-duration: 0.01ms !important;
      animation-iteration-count: 1 !important;
      transition-duration: 0.01ms !important;
      scroll-behavior: auto !important;
    }
  }
</style>
