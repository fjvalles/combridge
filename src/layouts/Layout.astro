---
interface Props {
  title?: string;
  description?: string;
  canonical?: string;
  ogImage?: string;
}

const {
  title = 'COMBRIDGE | Taller de liderazgo y gestión de proyectos — Comtraining',
  description = 'Construye un puente de 14 metros con tu equipo en 90 minutos. Taller experiencial de colaboración, liderazgo y gestión de proyectos. In-company en Chile.',
  canonical = 'https://combridge.comtraining.cl',
  ogImage = '/og-image.jpg',
} = Astro.props;
---

<!doctype html>
<html lang="es" hreflang="es-CL">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="generator" content={Astro.generator} />

    <!-- SEO -->
    <title>{title}</title>
    <meta name="description" content={description} />
    <link rel="canonical" href={canonical} />
    <link hreflang="es-CL" href={canonical} rel="alternate" />

    <!-- Open Graph -->
    <meta property="og:type" content="website" />
    <meta property="og:url" content={canonical} />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:image" content={`${canonical}${ogImage}`} />
    <meta property="og:image:width" content="1200" />
    <meta property="og:image:height" content="630" />
    <meta property="og:locale" content="es_CL" />
    <meta property="og:site_name" content="Comtraining" />

    <!-- Twitter Card -->
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={`${canonical}${ogImage}`} />

    <!-- Favicon -->
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />

    <!-- Google Fonts: Inter -->
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      rel="preload"
      as="style"
      href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800&display=swap"
    />
    <link
      href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800&display=swap"
      rel="stylesheet"
    />

    <!-- Schema.org: Course -->
    <script type="application/ld+json">
      {
        "@context": "https://schema.org",
        "@type": "Course",
        "name": "COMBRIDGE",
        "description": "Taller experiencial en el que equipos corporativos construyen un puente de 14 metros con 9.000 piezas en 90 minutos para desarrollar liderazgo, colaboración y gestión de proyectos.",
        "url": "https://combridge.comtraining.cl",
        "provider": {
          "@type": "Organization",
          "name": "Comtraining",
          "url": "https://comtraining.cl"
        },
        "educationalLevel": "Professional",
        "inLanguage": "es-CL",
        "courseMode": "in-person",
        "offers": {
          "@type": "Offer",
          "availability": "https://schema.org/InStock",
          "category": "In-company"
        },
        "instructor": {
          "@type": "Person",
          "name": "Francisco Vallés",
          "jobTitle": "Consultor y Coach Senior"
        }
      }
    </script>
  </head>
  <body>
    <slot />
  </body>
</html>

<style is:global>
  @import '../styles/global.css';

  :root {
    --color-brand: #3e5c76;
    --color-accent: #e63946;
    --color-text: #1f2937;
    --color-bg: #ffffff;
    --color-bg-soft: #f9fafb;
    --font-sans: 'Inter', ui-sans-serif, system-ui, sans-serif;
  }

  html {
    font-family: var(--font-sans);
    color: var(--color-text);
    background-color: var(--color-bg);
    scroll-behavior: smooth;
  }

  body {
    min-height: 100vh;
  }
</style>
