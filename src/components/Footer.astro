---
import { Mail, Globe, MapPin } from '@lucide/astro';
---

<footer class="footer">
  <div class="footer-inner">
    <div class="col col-marca">
      <img
        src="/images/logo-comtraining.png"
        alt="Comtraining"
        height="36"
        loading="lazy"
      />
      <p class="marca-desc">
        COMBRIDGE es un taller experiencial de Comtraining. Desarrollamos equipos
        que logran lo imposible.
      </p>
    </div>

    <div class="col col-links">
      <span class="col-titulo">Enlaces</span>
      <nav>
        <a href="#" class="nav-link">Inicio</a>
        <a href="#experiencia" class="nav-link">La experiencia</a>
        <a href="#agendar" class="nav-link">Agenda una reunión</a>
        <a href="/combridge-ficha.pdf" target="_blank" rel="noopener" class="nav-link">Descarga la ficha</a>
        <a href="https://comtraining.cl" target="_blank" rel="noopener" class="nav-link">comtraining.cl</a>
      </nav>
    </div>

    <div class="col col-contacto">
      <span class="col-titulo">Contacto</span>
      <ul class="contacto-list">
        <li>
          <Mail size={16} aria-hidden="true" class="contact-icon contact-icon--accent" />
          <span>contacto@comtraining.cl</span>
        </li>
        <li>
          <Globe size={16} aria-hidden="true" class="contact-icon" />
          <span>comtraining.cl</span>
        </li>
        <li>
          <MapPin size={16} aria-hidden="true" class="contact-icon" />
          <span>Santiago, Chile</span>
        </li>
      </ul>
    </div>
  </div>

  <div class="divider"></div>

  <div class="copyright">
    © 2025 Comtraining. Todos los derechos reservados. · combridge.comtraining.cl
  </div>
</footer>

<style>
  .footer {
    background-color: #1f2937;
    padding: 4rem 1.5rem 2rem;
  }

  .footer-inner {
    max-width: 1100px;
    margin: 0 auto;
    display: grid;
    grid-template-columns: 1fr;
    gap: 2.5rem;
    text-align: center;
  }

  @media (min-width: 860px) {
    .footer-inner {
      grid-template-columns: 1.4fr 1fr 1fr;
      gap: 3rem;
      text-align: left;
    }
  }

  /* ── Columna Marca ── */
  .col-marca img {
    height: 36px;
    width: auto;
    display: inline-block;
  }

  .marca-desc {
    margin-top: 0.875rem;
    font-size: 0.85rem;
    color: #94a3b8;
    line-height: 1.65;
    max-width: 280px;
  }

  @media (max-width: 859px) {
    .marca-desc {
      margin-left: auto;
      margin-right: auto;
    }
  }

  /* ── Columna títulos ── */
  .col-titulo {
    display: block;
    font-size: 0.72rem;
    font-weight: 700;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: #ffffff;
    margin-bottom: 1rem;
  }

  /* ── Links ── */
  nav {
    display: flex;
    flex-direction: column;
    gap: 0.6rem;
  }

  .nav-link {
    font-size: 0.875rem;
    color: #94a3b8;
    text-decoration: none;
    transition: color 0.2s ease;
  }

  .nav-link:hover {
    color: #ffffff;
  }

  /* ── Contacto ── */
  .contacto-list {
    list-style: none;
    margin: 0;
    padding: 0;
    display: flex;
    flex-direction: column;
    gap: 0.7rem;
  }

  .contacto-list li {
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 0.5rem;
    font-size: 0.875rem;
    color: #94a3b8;
  }

  @media (min-width: 860px) {
    .contacto-list li {
      justify-content: flex-start;
    }
  }

  .contacto-list :global(.contact-icon) {
    color: #94a3b8;
    flex-shrink: 0;
  }

  .contacto-list :global(.contact-icon--accent) {
    color: #e63946;
  }

  /* ── Divider ── */
  .divider {
    max-width: 1100px;
    margin: 2.5rem auto 1.5rem;
    border-top: 1px solid #374151;
  }

  /* ── Copyright ── */
  .copyright {
    max-width: 1100px;
    margin: 0 auto;
    font-size: 0.8rem;
    color: #64748b;
    text-align: center;
    line-height: 1.5;
  }
</style>
