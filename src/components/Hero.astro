---
import { HardHat, Building, Zap, Cpu, TrendingUp, ShoppingBag } from '@lucide/astro';

const floatingIndustries = [
  { Icon: HardHat,     name: 'Gran Minería',         delay: '0s',   duration: '5.8s', x: '10%', y: '34%' },
  { Icon: Zap,         name: 'Energía',              delay: '0.9s', duration: '6.4s', x: '52%', y: '32%' },
  { Icon: Building,    name: 'Construcción',         delay: '1.7s', duration: '5.2s', x: '42%', y: '54%' },
  { Icon: Cpu,         name: 'Tecnología',           delay: '0.4s', duration: '7s',   x: '8%',  y: '54%' },
  { Icon: ShoppingBag, name: 'Retail',               delay: '2.3s', duration: '6.1s', x: '81%', y: '54%' },
  { Icon: TrendingUp,  name: 'Servicios Financieros', delay: '1.1s', duration: '5.6s', x: '50%', y: '74%' },
];
---

<section class="hero">
  <div class="hero-backdrop"></div>
  <div class="hero-noise"></div>

  <div class="shell-wide hero-shell">
    <div class="hero-grid">
      <div class="hero-copy reveal visible">
        <p class="hero-context">Programa experiencial de Comtraining</p>
        <h1 class="hero-title">COMBRIDGE</h1>
        <p class="hero-lead">
          Construye un puente de <strong>14 metros</strong> con tu equipo en
          <strong>90 minutos</strong>, ensamblando 9.000 piezas. Un taller
          presencial que transforma liderazgo, colaboración y gestión de
          proyectos en resultados que se ven y se sienten.
        </p>

        <div class="hero-cloud hero-cloud-mobile reveal visible" aria-hidden="true">
          {floatingIndustries.map(({ Icon, name, delay, duration }) => (
            <div
              class="hero-industry-badge"
              style={`animation-delay: ${delay}; animation-duration: ${duration}`}
            >
              <Icon size={15} />
              <span>{name}</span>
            </div>
          ))}
        </div>

        <div class="button-row hero-actions">
          <a
            href="#agendar"
            class="button-primary"
            data-event="cta_hero_agendar">Agenda una reunión</a
          >
          <a
            href="#experiencia"
            class="button-secondary"
            data-event="cta_hero_experiencia">Ver la experiencia</a
          >
        </div>
      </div>

      <div class="hero-cloud hero-cloud-desktop reveal visible" aria-hidden="true">
        {floatingIndustries.map(({ Icon, name, delay, duration, x, y }) => (
          <div
            class="hero-industry-badge"
            style={`animation-delay: ${delay}; animation-duration: ${duration}; --badge-x: ${x}; --badge-y: ${y};`}
          >
            <Icon size={15} />
            <span>{name}</span>
          </div>
        ))}
      </div>
    </div>

    <a
      href="#experiencia"
      class="hero-scroll"
      aria-label="Ir a la siguiente sección"
    >
      Descubrir experiencia
    </a>
  </div>
</section>

<style>
  .hero {
    position: relative;
    min-height: 100svh;
    color: #fff;
    overflow: clip;
    isolation: isolate;
  }

  .hero-backdrop,
  .hero-noise {
    position: absolute;
    inset: 0;
  }

  .hero-backdrop {
    background:
      linear-gradient(
        110deg,
        rgba(6, 16, 26, 0.82) 18%,
        rgba(6, 16, 26, 0.52) 48%,
        rgba(6, 16, 26, 0.76) 100%
      ),
      radial-gradient(
        circle at 78% 24%,
        rgba(217, 109, 63, 0.28),
        transparent 22%
      ),
      url("/images/hero-colaboracion.jpg") center/cover no-repeat;
    transform: scale(1.04);
  }

  .hero-noise {
    background:
      linear-gradient(
        180deg,
        rgba(255, 255, 255, 0.02),
        transparent 34%,
        rgba(255, 255, 255, 0.02)
      ),
      radial-gradient(
        circle at bottom left,
        rgba(217, 109, 63, 0.12),
        transparent 30%
      );
    mix-blend-mode: screen;
    pointer-events: none;
  }

  .hero-shell {
    position: relative;
    z-index: 1;
    display: flex;
    min-height: 100svh;
    flex-direction: column;
    justify-content: center;
    padding: 6.5rem 0 2.25rem;
  }

  .hero-grid {
    display: grid;
    grid-template-columns: minmax(0, 1.02fr) minmax(320px, 0.78fr);
    gap: clamp(1.5rem, 3vw, 3rem);
    align-items: center;
    padding: 3rem 0;
  }

  .hero-copy {
    max-width: 680px;
  }

  .hero-context {
    margin: 0 0 1rem;
    color: rgba(255, 255, 255, 0.7);
    font-size: 0.82rem;
    font-weight: 800;
    letter-spacing: 0.16em;
    text-transform: uppercase;
    text-shadow: 0 2px 16px rgba(0, 0, 0, 0.45);
  }

  .hero-kicker {
    margin: 0 0 1.15rem;
    max-width: 34rem;
    color: rgba(255, 255, 255, 0.84);
    font-size: 0.98rem;
    line-height: 1.65;
    text-shadow: 0 4px 24px rgba(0, 0, 0, 0.45);
  }

  .hero-title {
    margin: 0;
    font-family: var(--font-display);
    font-size: clamp(4rem, 10vw, 8.6rem);
    line-height: 0.92;
    letter-spacing: -0.08em;
    text-shadow: 0 10px 32px rgba(0, 0, 0, 0.28);
  }

  .hero-lead {
    max-width: 38rem;
    margin: 1.35rem 0 0;
    color: rgba(255, 255, 255, 0.92);
    font-size: clamp(1.05rem, 2vw, 1.3rem);
    line-height: 1.7;
    text-shadow: 0 4px 24px rgba(0, 0, 0, 0.42);
  }

  .hero-lead strong {
    color: #fff;
    font-weight: 800;
  }

  .hero-actions {
    margin-top: 2rem;
    max-width: 38rem;
  }

  /* Cloud */
  .hero-cloud {
    display: flex;
    flex-wrap: wrap;
    gap: clamp(0.6rem, 1vw, 1.1rem);
    align-content: center;
    justify-content: flex-start;
    width: 100%;
    max-width: 100%;
  }

  .hero-cloud-mobile {
    display: none !important;
    justify-self: start;
  }

  .hero-cloud-desktop {
    position: relative;
    display: block !important;
    justify-self: stretch;
    align-self: stretch;
    min-height: clamp(22rem, 34vw, 31rem);
    margin-left: clamp(1.5rem, 4vw, 4.5rem);
  }

  .hero-cloud-desktop .hero-industry-badge {
    position: absolute;
    left: var(--badge-x);
    top: var(--badge-y);
  }

  .hero-industry-badge {
    display: inline-flex;
    align-items: center;
    gap: clamp(0.35rem, 0.7vw, 0.55rem);
    padding: clamp(0.45rem, 0.7vw, 0.62rem) clamp(0.7rem, 1vw, 1rem);
    border-radius: 999px;
    border: 1px solid rgba(255, 255, 255, 0.16);
    background: rgba(255, 255, 255, 0.08);
    backdrop-filter: blur(12px);
    color: rgba(255, 255, 255, 0.72);
    font-size: clamp(0.72rem, 0.78vw, 0.92rem);
    font-weight: 700;
    white-space: nowrap;
    animation: float 6s ease-in-out infinite;
  }

  .hero-industry-badge :global(svg) {
    width: clamp(0.82rem, 0.9vw, 1rem);
    height: clamp(0.82rem, 0.9vw, 1rem);
    flex-shrink: 0;
  }

  @keyframes float {
    0%, 100% { transform: translateY(0);    }
    50%       { transform: translateY(-9px); }
  }

  .hero-scroll {
    display: inline-flex;
    align-items: center;
    gap: 0.8rem;
    width: fit-content;
    color: rgba(255, 255, 255, 0.72);
    text-decoration: none;
    font-size: 0.84rem;
    font-weight: 700;
    letter-spacing: 0.16em;
    text-transform: uppercase;
  }

  .hero-scroll::after {
    content: "";
    width: 4rem;
    height: 1px;
    background: currentColor;
  }

  @media (max-width: 960px) {
    .hero-grid {
      grid-template-columns: 1fr;
      padding: 2.25rem 0;
    }

    .hero-cloud-desktop {
      display: none !important;
    }

    .hero-cloud-mobile {
      display: flex !important;
    }

    .hero-cloud {
      gap: 0.55rem;
      margin-top: 1.1rem;
      margin-bottom: 0.9rem;
      max-width: 30rem;
      justify-self: start;
      align-content: flex-start;
    }

    .hero-industry-badge {
      padding: 0.42rem 0.68rem;
      font-size: 0.72rem;
      color: rgba(255, 255, 255, 0.76);
    }

    .hero-actions {
      gap: 0.75rem;
      margin-top: 2rem;
      max-width: none;
    }
  }

  @media (max-width: 720px) {
    .hero-backdrop {
      background:
        linear-gradient(
          180deg,
          rgba(6, 16, 26, 0.9) 0%,
          rgba(6, 16, 26, 0.68) 34%,
          rgba(6, 16, 26, 0.8) 100%
        ),
        linear-gradient(
          110deg,
          rgba(6, 16, 26, 0.88) 10%,
          rgba(6, 16, 26, 0.5) 55%,
          rgba(6, 16, 26, 0.82) 100%
        ),
        radial-gradient(
          circle at 78% 24%,
          rgba(217, 109, 63, 0.22),
          transparent 22%
        ),
        url("/images/hero-colaboracion.jpg") center/cover no-repeat;
    }

    .hero-shell {
      justify-content: flex-start;
      padding-top: 6.9rem;
      padding-bottom: 1rem;
    }

    .hero-copy {
      max-width: 100%;
    }

    .hero-title {
      font-size: clamp(2.8rem, 14vw, 4.4rem);
    }

    .hero-lead {
      font-size: 1rem;
      line-height: 1.6;
      max-width: 19rem;
    }

    .hero-cloud {
      max-width: 22rem;
    }

    .hero-scroll {
      display: none;
    }
  }

  @media (max-width: 420px) {
    .hero-grid {
      gap: 1.35rem;
      padding: 1.25rem 0 1.75rem;
    }

    .hero-context {
      margin-bottom: 0.7rem;
      font-size: 0.74rem;
    }

    .hero-kicker {
      margin-bottom: 0.9rem;
      font-size: 0.92rem;
      max-width: 18rem;
    }

    .hero-cloud {
      gap: 0.5rem;
      margin-top: 1rem;
      margin-bottom: 1rem;
      max-width: 100%;
    }

    .hero-industry-badge {
      padding: 0.38rem 0.62rem;
      font-size: 0.68rem;
      animation: none;
    }

    .hero-actions {
      margin-top: 2.1rem;
    }
  }
</style>
