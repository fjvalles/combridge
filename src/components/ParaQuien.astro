---
import { Briefcase, FolderKanban, Building2 } from '@lucide/astro';

const cards = [
  {
    Icon: Briefcase,
    titulo: 'Líderes y gerentes',
    desc: 'Fortalece tu capacidad de guiar equipos en proyectos de incertidumbre y alta presión, alineando esfuerzos individuales hacia metas ambiciosas.',
  },
  {
    Icon: FolderKanban,
    titulo: 'Equipos de proyectos',
    desc: 'Mejora la comunicación, colaboración y ejecución de tu equipo desarrollando estrategias efectivas para alcanzar objetivos comunes en entornos desafiantes.',
  },
  {
    Icon: Building2,
    titulo: 'Organizaciones en transformación',
    desc: 'Fomenta una cultura de innovación, resiliencia y trabajo en equipo para enfrentar desafíos complejos en entornos dinámicos.',
  },
];
---

<section class="para-quien" id="para-quien">
  <div class="para-quien-inner">
    <div class="header fade-in">
      <span class="eyebrow">¿Para quién es?</span>
      <h2 class="titulo">Diseñado para líderes que quieren resultados reales</h2>
    </div>

    <div class="cards-grid">
      {cards.map((card, i) => (
        <article class="card fade-in" style={`transition-delay: ${i * 120}ms`}>
          <div class="card-icon">
            <card.Icon size={40} color="#E63946" aria-hidden="true" />
          </div>
          <h3 class="card-titulo">{card.titulo}</h3>
          <p class="card-desc">{card.desc}</p>
        </article>
      ))}
    </div>
  </div>
</section>

<script>
  const observer = new IntersectionObserver(
    (entries) => {
      entries.forEach((entry) => {
        if (entry.isIntersecting) {
          entry.target.classList.add('visible');
          observer.unobserve(entry.target);
        }
      });
    },
    { threshold: 0.12 }
  );

  document.querySelectorAll('#para-quien .fade-in').forEach((el) => observer.observe(el));
</script>

<style>
  .para-quien {
    background-color: #3e5c76;
    padding: 5rem 1.5rem;
  }

  .para-quien-inner {
    max-width: 1100px;
    margin: 0 auto;
  }

  /* ── Header ── */
  .header {
    text-align: center;
    margin-bottom: 3rem;
  }

  .eyebrow {
    display: block;
    font-size: 0.78rem;
    font-weight: 700;
    letter-spacing: 0.14em;
    text-transform: uppercase;
    color: #e63946;
    margin-bottom: 0.75rem;
  }

  .titulo {
    font-size: clamp(1.5rem, 3.5vw, 2.1rem);
    font-weight: 800;
    color: #ffffff;
    line-height: 1.25;
    max-width: 600px;
    margin: 0 auto;
  }

  /* ── Grid ── */
  .cards-grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: 1.25rem;
  }

  @media (min-width: 860px) {
    .cards-grid {
      grid-template-columns: repeat(3, 1fr);
      gap: 1.5rem;
    }
  }

  /* ── Card ── */
  .card {
    background: rgba(255, 255, 255, 0.08);
    border: 1px solid rgba(255, 255, 255, 0.15);
    border-top: 3px solid transparent;
    border-radius: 12px;
    padding: 2rem 1.75rem;
    display: flex;
    flex-direction: column;
    gap: 0.85rem;
    transition: background 0.2s ease, border-top-color 0.2s ease;
  }

  .card:hover {
    background: rgba(255, 255, 255, 0.15);
    border-top-color: #e63946;
  }

  .card-icon {
    display: flex;
    align-items: center;
  }

  .card-titulo {
    font-size: 1.1rem;
    font-weight: 700;
    color: #ffffff;
    line-height: 1.3;
  }

  .card-desc {
    font-size: 0.9rem;
    color: rgba(255, 255, 255, 0.75);
    line-height: 1.7;
  }

  /* ── Fade-in ── */
  .fade-in {
    opacity: 0;
    transform: translateY(20px);
    transition: opacity 0.55s ease, transform 0.55s ease;
  }

  .fade-in.visible {
    opacity: 1;
    transform: translateY(0);
  }
</style>
