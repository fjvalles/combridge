---
import {
  Briefcase,
  FolderKanban,
  Building2,
} from '@lucide/astro';

const audiences = [
  {
    Icon: Briefcase,
    title: 'Líderes y gerentes',
    desc: 'Para quienes necesitan alinear equipos exigidos por objetivos ambiciosos, plazos tensos y decisiones que no pueden esperar.',
  },
  {
    Icon: FolderKanban,
    title: 'Equipos de proyecto',
    desc: 'Ideal para equipos que quieren mejorar coordinación transversal, priorización y ejecución en contextos de alta dependencia.',
  },
  {
    Icon: Building2,
    title: 'Organizaciones en transformación',
    desc: 'Especialmente potente cuando la empresa está cambiando cultura, procesos o formas de colaborar entre áreas.',
  },
];

---

<section class="section para-quien" id="para-quien">
  <div class="shell para-quien-shell">
    <div class="section-intro reveal">
      <span class="eyebrow">Para quién es</span>
      <h2 class="section-title">Diseñado para equipos que no pueden darse el lujo de coordinar mal.</h2>
      <p class="section-copy">
        COMBRIDGE funciona mejor donde la ejecución importa de verdad: proyectos complejos,
        liderazgo transversal y organizaciones que buscan que la colaboración deje de ser
        una intención y se convierta en una capacidad concreta.
      </p>
    </div>

    <div class="audience-grid">
      {audiences.map((audience, index) => (
        <article class="audience reveal" style={`transition-delay: ${index * 100}ms`}>
          <div class="audience-icon">
            <audience.Icon size={28} aria-hidden="true" />
          </div>
          <h3>{audience.title}</h3>
          <p>{audience.desc}</p>
        </article>
      ))}
    </div>
  </div>
</section>

<script>
  const observer = new IntersectionObserver(
    (entries) => {
      entries.forEach((entry) => {
        if (entry.isIntersecting) {
          entry.target.classList.add('visible');
          observer.unobserve(entry.target);
        }
      });
    },
    { threshold: 0.15 }
  );

  document.querySelectorAll('#para-quien .reveal').forEach((el) => observer.observe(el));
</script>

<style>
  .para-quien {
    position: relative;
    color: #193042;
    background:
      radial-gradient(circle at top left, rgba(217, 109, 63, 0.1), transparent 28%),
      radial-gradient(circle at bottom right, rgba(16, 33, 49, 0.08), transparent 34%),
      linear-gradient(180deg, #f6efe7 0%, #f1e7dc 100%);
  }

  .para-quien::before {
    content: '';
    position: absolute;
    inset: 0 0 auto;
    height: 1px;
    background: linear-gradient(90deg, transparent, rgba(25, 48, 66, 0.18), transparent);
  }

  .para-quien-shell {
    position: relative;
  }

  .para-quien :global(.section-title),
  .para-quien :global(.section-copy) {
    color: inherit;
  }

  .para-quien :global(.section-copy) {
    color: rgba(25, 48, 66, 0.74);
  }

  .para-quien .eyebrow {
    color: #c96c3d;
  }

  .audience-grid {
    display: grid;
    grid-template-columns: repeat(3, minmax(0, 1fr));
    gap: 1rem;
    margin-bottom: 1.2rem;
  }

  .audience {
    padding: 1.7rem;
    border: 1px solid rgba(25, 48, 66, 0.1);
    border-radius: 24px;
    background:
      linear-gradient(180deg, rgba(255, 255, 255, 0.84), rgba(255, 255, 255, 0.68)),
      rgba(255, 255, 255, 0.72);
    box-shadow:
      0 20px 50px rgba(17, 31, 44, 0.08),
      inset 0 1px 0 rgba(255, 255, 255, 0.7);
    backdrop-filter: blur(10px);
  }

  .audience-icon {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 3.2rem;
    height: 3.2rem;
    border-radius: 18px;
    background: rgba(217, 109, 63, 0.14);
    color: #c96c3d;
    border: 1px solid rgba(217, 109, 63, 0.18);
  }

  .audience h3 {
    margin: 1.2rem 0 0;
    font-size: 1.18rem;
    line-height: 1.3;
    color: #193042;
  }

  .audience p {
    margin: 0.85rem 0 0;
    color: rgba(25, 48, 66, 0.72);
    line-height: 1.8;
  }
  @media (max-width: 960px) {
    .audience-grid {
      grid-template-columns: 1fr;
    }
  }

  @media (max-width: 480px) {
    .audience {
      padding: 1rem;
    }
  }
</style>
