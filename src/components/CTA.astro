---

<section class="section cta" id="agendar">
  <div class="shell cta-shell">
    <div class="cta-copy reveal">
      <span class="eyebrow">Agenda una reunión</span>
      <h2 class="section-title">Veamos si COMBRIDGE es para tu equipo.</h2>
      <p class="section-copy">
        Revisamos contexto y objetivos. Si hay buen encaje, saldrás con una recomendación
        concreta de formato para avanzar.
      </p>

      <p class="cta-contact">
        ¿Prefieres escribirnos? <a href="mailto:contacto@comtraining.cl">contacto@comtraining.cl</a>
      </p>
    </div>

    <div class="cta-embed reveal">
      <iframe
        src="https://cal.com/fjvalles?embed=true&theme=light&brandColor=%2314324A"
        title="Agendar reunión con Francisco Vallés"
        loading="lazy"
        allow="camera; microphone"
        class="cta-frame"
        style="width:100%;border:none;background:transparent;"
      ></iframe>
    </div>
  </div>
</section>

<script>
  const observer = new IntersectionObserver(
    (entries) => {
      entries.forEach((entry) => {
        if (entry.isIntersecting) {
          entry.target.classList.add('visible');
          observer.unobserve(entry.target);
        }
      });
    },
    { threshold: 0.16 }
  );

  document.querySelectorAll('#agendar .reveal').forEach((el) => observer.observe(el));
</script>

<style>
  .cta {
    color: #fff;
    background:
      radial-gradient(circle at top left, rgba(217, 109, 63, 0.18), transparent 28%),
      linear-gradient(180deg, #14324a 0%, #0b1c2d 100%);
  }

  .cta-shell {
    display: grid;
    grid-template-columns: minmax(0, 0.82fr) minmax(0, 1.18fr);
    gap: 2rem;
    align-items: start;
  }

  .cta :global(.section-title),
  .cta :global(.section-copy) {
    color: inherit;
  }

  .cta :global(.section-copy) {
    color: rgba(255, 255, 255, 0.72);
  }

  .cta-highlights {
    display: grid;
    gap: 0.8rem;
    margin-top: 2rem;
  }

  .cta-highlights span {
    display: flex;
    align-items: center;
    gap: 0.8rem;
    color: rgba(255, 255, 255, 0.86);
    font-weight: 700;
  }

  .cta-highlights span::before {
    content: '';
    width: 0.72rem;
    height: 0.72rem;
    border-radius: 999px;
    background: var(--color-accent);
    box-shadow: 0 0 0 8px rgba(217, 109, 63, 0.16);
    flex-shrink: 0;
  }

  .cta-contact {
    margin: 2rem 0 0;
    color: rgba(255, 255, 255, 0.72);
    line-height: 1.7;
  }

  .cta-contact a {
    color: #fff;
    font-weight: 700;
    text-decoration: none;
    border-bottom: 1px solid rgba(255, 255, 255, 0.3);
  }

  .cta-embed {
    overflow: hidden;
    border-radius: var(--radius-lg);
    border: 1px solid rgba(255, 255, 255, 0.14);
    background: rgba(255, 255, 255, 0.95);
    box-shadow: var(--shadow-strong);
  }

  .cta-frame {
    display: block;
    min-height: 700px;
  }

  @media (max-width: 960px) {
    .cta-shell {
      grid-template-columns: 1fr;
    }
    /* En móvil, el calendario primero */
    .cta-embed {
      order: -1;
    }
  }

  @media (max-width: 720px) {
    .cta-frame {
      min-height: 620px;
    }
  }
</style>
