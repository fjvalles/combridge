---
---

<section class="cta" id="agendar">
  <div class="cta-inner">
    <span class="eyebrow">Agenda una reunión</span>
    <h2 class="titulo">Conversemos sobre tu equipo</h2>
    <p class="subtitulo">
      30 minutos para explorar cómo COMBRIDGE puede transformar la forma en que
      tu equipo colabora y ejecuta proyectos.
    </p>

    <div class="embed-wrap">
      <iframe
        src="https://cal.com/fjvalles?embed=true&theme=light&brandColor=%233E5C76"
        title="Agendar reunión con Francisco Vallés"
        loading="lazy"
        allow="camera; microphone"
        style="width:100%;height:660px;border:none;border-radius:12px;background:transparent;"
      ></iframe>
    </div>

    <p class="contacto">
      ¿Prefieres escribirnos?&nbsp;
      <a href="mailto:contacto@comtraining.cl">contacto@comtraining.cl</a>
    </p>
  </div>
</section>

<style>
  .cta {
    background-color: #3e5c76;
    padding: 5rem 1.5rem 4rem;
  }

  .cta-inner {
    max-width: 900px;
    margin: 0 auto;
    display: flex;
    flex-direction: column;
    align-items: center;
  }

  .eyebrow {
    display: block;
    font-size: 0.78rem;
    font-weight: 700;
    letter-spacing: 0.14em;
    text-transform: uppercase;
    color: #e63946;
    margin-bottom: 0.75rem;
  }

  .titulo {
    font-size: clamp(1.6rem, 3.4vw, 2.2rem);
    font-weight: 800;
    color: #ffffff;
    text-align: center;
    line-height: 1.2;
    margin: 0 0 1rem;
  }

  .subtitulo {
    font-size: 1rem;
    color: rgba(255, 255, 255, 0.8);
    text-align: center;
    line-height: 1.7;
    max-width: 560px;
    margin: 0 0 2.5rem;
  }

  .embed-wrap {
    width: 100%;
    border-radius: 12px;
    overflow: hidden;
    background: #ffffff;
  }

  .contacto {
    margin-top: 1.5rem;
    font-size: 0.875rem;
    color: rgba(255, 255, 255, 0.6);
    text-align: center;
  }

  .contacto a {
    color: rgba(255, 255, 255, 0.6);
    text-decoration: underline;
    text-underline-offset: 3px;
    transition: color 0.2s ease;
  }

  .contacto a:hover {
    color: rgba(255, 255, 255, 0.9);
  }
</style>
