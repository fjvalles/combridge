---
const links = [
  { href: '#experiencia', label: 'Experiencia' },
  { href: '#aprendizajes', label: 'Aprendizajes' },
  { href: '#para-quien', label: 'Para quién' },
  { href: '#profesor', label: 'Facilitador' },
  { href: '#faq', label: 'FAQ' },
