    </a>

    <nav class="header-nav" aria-label="Navegación principal">
      {links.map((link) => (
        <a href={link.href}>{link.label}</a>
      ))}
    </nav>

    <a href="#agendar" class="header-cta" data-event="cta_header_agendar">Agendar</a>
  </div>
</header>

<script>
  const header = document.querySelector<HTMLElement>('[data-site-header]');
  if (header) {
    const onScroll = () => {
      if (window.scrollY > 80) header.classList.add('is-scrolled');
      else header.classList.remove('is-scrolled');
    };
    onScroll();
    window.addEventListener('scroll', onScroll, { passive: true });
  }
</script>

<style>
  .site-header {
    position: fixed;
    top: 0;
    left: 0;
    right: 0;
    z-index: 50;
    padding: max(0.75rem, env(safe-area-inset-top)) 0 0.75rem;
    transition: background-color 0.3s ease, box-shadow 0.3s ease, backdrop-filter 0.3s ease;
  }

  .site-header.is-scrolled {
    background: rgba(251, 248, 243, 0.9);
    backdrop-filter: blur(16px);
    box-shadow: 0 8px 24px rgba(8, 20, 32, 0.06);
  }

  .header-shell {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 1.5rem;
    flex-wrap: wrap;
  }

  .header-brand {
    display: inline-flex;
    align-items: center;
    padding: 0.5rem 0.7rem;
    border: 1px solid rgba(255, 255, 255, 0.12);
    border-radius: 999px;
    background: rgba(255, 255, 255, 0.06);
    backdrop-filter: blur(14px);
    text-decoration: none;
    transition:
      background-color 0.25s ease,
      border-color 0.25s ease,
      box-shadow 0.25s ease;
  }

  .header-logo {
    height: 1.75rem;
    width: auto;
    display: block;
    color: #fff;
    transition: color 0.3s ease;
  }

  .header-brand:hover {
    background: rgba(255, 255, 255, 0.1);
    border-color: rgba(255, 255, 255, 0.18);
    box-shadow: 0 10px 24px rgba(8, 20, 32, 0.12);
  }

  .header-nav {
    display: flex;
    gap: 1.6rem;
    align-items: center;
  }

  .header-nav a {
    color: rgba(255, 255, 255, 0.82);
    font-size: 0.92rem;
    font-weight: 600;
    text-decoration: none;
    transition: color 0.25s ease;
    white-space: nowrap;
    touch-action: manipulation;
  }

  .header-nav a:hover {
    color: #fff;
  }

  .site-header.is-scrolled .header-nav a {
    color: var(--color-text-soft);
  }

  .site-header.is-scrolled .header-brand {
    background: rgba(255, 255, 255, 0.9);
    border-color: rgba(16, 33, 49, 0.08);
    box-shadow: 0 10px 24px rgba(8, 20, 32, 0.08);
  }

  .site-header.is-scrolled .header-logo {
    color: #1F2937;
  }

  .site-header.is-scrolled .header-nav a:hover {
    color: var(--color-text);
  }

  .header-cta {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    padding: 0.6rem 1.1rem;
    border-radius: 999px;
    background: var(--color-accent);
    color: #fff8f4;
    font-size: 0.9rem;
    font-weight: 700;
    text-decoration: none;
    box-shadow: 0 8px 20px rgba(217, 109, 63, 0.28);
    transition: transform 0.25s ease, background-color 0.25s ease;
    touch-action: manipulation;
  }

  .header-cta:hover {
    transform: translateY(-1px);
    background: #c85d31;
  }

  @media (max-width: 860px) {
    .site-header {
      background: linear-gradient(180deg, rgba(11, 28, 45, 0.9), rgba(11, 28, 45, 0.62));
      backdrop-filter: blur(18px);
      box-shadow: 0 10px 24px rgba(8, 20, 32, 0.18);
      padding-bottom: 0.55rem;
    }

    .header-shell {
      display: flex;
      justify-content: space-between;
      gap: 0.75rem;
      align-items: center;
      flex-wrap: nowrap;
    }

    .header-brand {
      padding: 0.5rem 0.75rem;
      border-color: rgba(255, 255, 255, 0.18);
      background: rgba(255, 255, 255, 0.12);
      box-shadow: 0 10px 24px rgba(8, 20, 32, 0.16);
    }

    .header-logo {
      height: 1.6rem;
      color: #fff;
    }

    .header-nav {
      display: none;
    }

    .header-cta {
      flex: 0 0 auto;
      padding: 0.7rem 0.95rem;
      min-height: 2.7rem;
      font-size: 0.86rem;
    }
  }
</style>
