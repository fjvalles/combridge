---
import { HardHat, Building, Zap, Cpu, TrendingUp, ShoppingBag } from '@lucide/astro';

const industrias = [
  { Icon: HardHat,     nombre: 'Gran Minería'            },
  { Icon: Building,    nombre: 'Construcción e Ingeniería'},
  { Icon: Zap,         nombre: 'Energía'                 },
  { Icon: Cpu,         nombre: 'Tecnología'              },
  { Icon: TrendingUp,  nombre: 'Financiera'              },
  { Icon: ShoppingBag, nombre: 'Retail'                  },
];
---

<section class="industrias" id="industrias">
  <div class="industrias-inner">
    <div class="header fade-in">
      <span class="eyebrow">Industrias</span>
      <h2 class="titulo">Probado en las industrias más exigentes de Chile</h2>
      <p class="subtitulo">
        Especialmente exitoso en equipos de proyectos donde la coordinación, la presión
        y los plazos ajustados son parte del día a día.
      </p>
    </div>

    <div class="grid fade-in fade-in--delay">
      {industrias.map(({ Icon, nombre }) => (
        <div class="item">
          <div class="item-icon">
            <Icon size={40} aria-hidden="true" />
          </div>
          <span class="item-nombre">{nombre}</span>
        </div>
      ))}
    </div>

    <hr class="divisor fade-in fade-in--delay2" />
  </div>
</section>

<script>
  const observer = new IntersectionObserver(
    (entries) => {
      entries.forEach((entry) => {
        if (entry.isIntersecting) {
          entry.target.classList.add('visible');
          observer.unobserve(entry.target);
        }
      });
    },
    { threshold: 0.15 }
  );

  document.querySelectorAll('#industrias .fade-in').forEach((el) => observer.observe(el));
</script>

<style>
  .industrias {
    background-color: #ffffff;
    padding: 4rem 1.5rem;
  }

  .industrias-inner {
    max-width: 1100px;
    margin: 0 auto;
  }

  /* ── Header ── */
  .header {
    text-align: center;
    margin-bottom: 3rem;
  }

  .eyebrow {
    display: block;
    font-size: 0.78rem;
    font-weight: 700;
    letter-spacing: 0.14em;
    text-transform: uppercase;
    color: #e63946;
    margin-bottom: 0.75rem;
  }

  .titulo {
    font-size: clamp(1.4rem, 3.2vw, 2rem);
    font-weight: 800;
    color: #1f2937;
    line-height: 1.25;
    margin-bottom: 0.875rem;
  }

  .subtitulo {
    font-size: 1rem;
    color: #64748b;
    max-width: 600px;
    margin: 0 auto;
    line-height: 1.65;
  }

  /* ── Grid ── */
  .grid {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: 2rem 1rem;
  }

  @media (min-width: 580px) {
    .grid {
      grid-template-columns: repeat(3, 1fr);
    }
  }

  @media (min-width: 900px) {
    .grid {
      grid-template-columns: repeat(6, 1fr);
      gap: 1rem;
    }
  }

  /* ── Item ── */
  .item {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 0.6rem;
    cursor: default;
  }

  .item-icon {
    color: #3e5c76;
    transition: color 0.2s ease;
    display: flex;
    align-items: center;
    justify-content: center;
  }

  .item-nombre {
    font-size: 0.82rem;
    font-weight: 700;
    color: #1f2937;
    text-align: center;
    line-height: 1.3;
    transition: color 0.2s ease;
  }

  .item:hover .item-icon {
    color: #e63946;
  }

  .item:hover .item-nombre {
    color: #3e5c76;
  }

  /* ── Divisor ── */
  .divisor {
    border: none;
    border-top: 1px solid #e2e8f0;
    margin-top: 3.5rem;
  }

  /* ── Fade-in ── */
  .fade-in {
    opacity: 0;
    transform: translateY(18px);
    transition: opacity 0.55s ease, transform 0.55s ease;
  }

  .fade-in--delay  { transition-delay: 0.15s; }
  .fade-in--delay2 { transition-delay: 0.25s; }

  .fade-in.visible {
    opacity: 1;
    transform: translateY(0);
  }
</style>
