---
import { HardHat, Building, Zap, Cpu, TrendingUp, ShoppingBag } from '@lucide/astro';

const industries = [
  { Icon: HardHat, name: 'Gran Minería' },
  { Icon: Building, name: 'Construcción e Ingeniería' },
  { Icon: Zap, name: 'Energía' },
  { Icon: Cpu, name: 'Tecnología' },
  { Icon: TrendingUp, name: 'Servicios Financieros' },
  { Icon: ShoppingBag, name: 'Retail' },
];
---

<section class="section industrias" id="industrias">
  <div class="shell">
    <div class="industrias-head reveal">
      <div class="section-intro">
        <span class="eyebrow">Industrias</span>
        <h2 class="section-title">Diseñado para entornos donde la exigencia es parte del negocio.</h2>
      </div>
      <p class="section-copy">
        La metodología se adapta al contexto de cada equipo. Funciona especialmente bien
        en industrias donde coordinación, presión y plazos ajustados son parte del día a día.
      </p>
    </div>

    <div class="industrias-grid reveal">
      {industries.map(({ Icon, name }) => (
        <div class="industry">
          <div class="industry-icon">
            <Icon size={34} aria-hidden="true" />
          </div>
          <span>{name}</span>
        </div>
      ))}
    </div>
  </div>
</section>

<script>
  const observer = new IntersectionObserver(
    (entries) => {
      entries.forEach((entry) => {
        if (entry.isIntersecting) {
          entry.target.classList.add('visible');
          observer.unobserve(entry.target);
        }
      });
    },
    { threshold: 0.15 }
  );

  document.querySelectorAll('#industrias .reveal').forEach((el) => observer.observe(el));
</script>

<style>
  .industrias-head {
    display: grid;
    grid-template-columns: minmax(0, 1fr) minmax(0, 0.75fr);
    gap: 1.5rem;
    align-items: end;
    margin-bottom: 1.5rem;
  }

  .industrias-head :global(.section-copy) {
    margin-top: 0;
  }

  .industrias-grid {
    display: grid;
    grid-template-columns: repeat(6, minmax(0, 1fr));
    gap: 0.5rem;
  }

  .industry {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 0.5rem;
    padding: 0.75rem 0.5rem;
    border-bottom: 2px solid var(--color-brand);
    text-align: center;
  }

  .industry-icon {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 2.25rem;
    height: 2.25rem;
    border-radius: 10px;
    background: rgba(20, 50, 74, 0.07);
    color: var(--color-brand);
  }

  .industry span {
    font-size: 0.78rem;
    font-weight: 700;
    line-height: 1.3;
  }

  @media (max-width: 960px) {
    .industrias-head {
      grid-template-columns: 1fr;
    }

    .industrias-grid {
      grid-template-columns: repeat(3, minmax(0, 1fr));
    }
  }

  @media (max-width: 480px) {
    .industrias-grid {
      grid-template-columns: repeat(2, minmax(0, 1fr));
    }
  }
</style>
