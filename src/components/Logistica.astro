---
import { Clock, MapPin, Users, CheckCircle } from '@lucide/astro';

const items = [
  { Icon: Clock, data: '4 horas', label: 'duración total del taller' },
  { Icon: MapPin, data: 'In-company', label: 'vamos donde esté tu equipo' },
  { Icon: Users, data: 'Hasta 35 personas', label: 'por sesión' },
  { Icon: CheckCircle, data: 'Presencial', label: 'modalidad' },
];
---

<section class="section logistica" id="logistica">
  <div class="shell logistica-shell reveal">
    <div class="logistica-heading">
      <span class="eyebrow">Logística</span>
      <h2 class="section-title">Simple de implementar. Potente de vivir.</h2>
    </div>

    <div class="logistica-grid">
      {items.map(({ Icon, data, label }) => (
        <article class="logistica-item">
          <div class="logistica-icon">
            <Icon size={28} aria-hidden="true" />
          </div>
          <strong>{data}</strong>
          <span>{label}</span>
        </article>
      ))}
    </div>
  </div>
</section>

<script>
  const observer = new IntersectionObserver(
    (entries) => {
      entries.forEach((entry) => {
        if (entry.isIntersecting) {
          entry.target.classList.add('visible');
          observer.unobserve(entry.target);
        }
      });
    },
    { threshold: 0.18 }
  );

  document.querySelectorAll('#logistica .reveal').forEach((el) => observer.observe(el));
</script>

<style>
  .logistica-shell {
    display: grid;
    grid-template-columns: minmax(0, 0.8fr) minmax(0, 1.2fr);
    gap: 2rem;
    padding: 2rem;
    border-radius: var(--radius-lg);
    background: linear-gradient(180deg, rgba(255, 255, 255, 0.8), rgba(255, 255, 255, 0.58));
    box-shadow: var(--shadow-soft);
  }

  .logistica-grid {
    display: grid;
    grid-template-columns: repeat(2, minmax(0, 1fr));
    gap: 1rem;
  }

  .logistica-item {
    padding: 1.25rem;
    border-radius: 24px;
    background: rgba(20, 50, 74, 0.04);
  }

  .logistica-icon {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 3rem;
    height: 3rem;
    border-radius: 16px;
    background: #ffffff;
    color: var(--color-brand);
    box-shadow: var(--shadow-soft);
  }

  .logistica-item strong {
    display: block;
    margin-top: 1rem;
    font-family: var(--font-display);
    font-size: 1.5rem;
    letter-spacing: -0.05em;
  }

  .logistica-item span {
    display: block;
    margin-top: 0.45rem;
    color: var(--color-text-soft);
    line-height: 1.6;
  }

  @media (max-width: 960px) {
    .logistica-shell,
    .logistica-grid {
      grid-template-columns: 1fr;
    }
  }

  @media (max-width: 720px) {
    .logistica-shell {
      padding: 1.2rem;
    }
  }
</style>
