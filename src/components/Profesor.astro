---
import { GraduationCap, Globe, Award, Users } from "@lucide/astro";

const credentials = [
  { Icon: GraduationCap, text: "Profesor UAI" },
  { Icon: Globe, text: "25+ años de experiencia" },
  { Icon: Award, text: "Ingeniero Civil Industrial PUC" },
  { Icon: Users, text: "Coach ejecutivo" },
];
---

<section class="section profesor" id="profesor">
  <div class="shell profesor-grid">
    <div class="profesor-copy reveal">
      <span class="eyebrow">El facilitador</span>
      <h2 class="section-title">
        Experiencia que se nota en sala.
      </h2>
      <p class="section-copy">
        Francisco Vallés aporta algo más que facilitación: criterio para leer lo que pasa
        en el equipo, conectar la experiencia con desafíos reales y convertirla en
        aprendizajes aplicables.
      </p>
      <p class="section-copy">
        Es consultor, coach ejecutivo y profesor de habilidades directivas, con más de 25
        años de experiencia acompañando procesos de liderazgo, cambio y coordinación en
        organizaciones complejas.
      </p>

      <div class="credentials">
        {
          credentials.map(({ Icon, text }) => (
            <div class="credential">
              <Icon size={18} aria-hidden="true" />
              <span>{text}</span>
            </div>
          ))
        }
      </div>
    </div>

    <div class="profesor-media reveal">
      <div class="portrait-frame">
        <img
          src="/images/francisco_valles2.png"
          alt="Francisco Vallés, consultor y coach senior, facilitador del taller COMBRIDGE de Comtraining"
          width="520"
          height="650"
          loading="lazy"
        />
      </div>
      <div class="portrait-caption">
        <span>Socio Comtraining</span>
        <strong>Profesor UAI y facilitador senior</strong>
      </div>
    </div>
  </div>
</section>

<script>
  const observer = new IntersectionObserver(
    (entries) => {
      entries.forEach((entry) => {
        if (entry.isIntersecting) {
          entry.target.classList.add("visible");
          observer.unobserve(entry.target);
        }
      });
    },
    { threshold: 0.18 },
  );

  document
    .querySelectorAll("#profesor .reveal")
    .forEach((el) => observer.observe(el));
</script>

<style>
  .profesor {
    background: rgba(255, 255, 255, 0.34);
  }

  .profesor-grid {
    display: grid;
    grid-template-columns: minmax(0, 1fr) minmax(320px, 0.8fr);
    gap: 3rem;
    align-items: center;
  }

  .credentials {
    display: grid;
    grid-template-columns: repeat(2, minmax(0, 1fr));
    gap: 0.9rem;
    margin-top: 2rem;
  }

  .credential {
    display: flex;
    align-items: center;
    gap: 0.7rem;
    padding: 0.9rem 1rem;
    border-radius: 18px;
    background: rgba(255, 255, 255, 0.72);
    box-shadow: var(--shadow-soft);
    font-size: 0.92rem;
    font-weight: 700;
  }

  .credential :global(svg) {
    color: var(--color-brand);
    flex-shrink: 0;
  }

  .profesor-media {
    position: relative;
  }

  .portrait-frame {
    overflow: hidden;
    border-radius: var(--radius-lg);
    box-shadow: var(--shadow-strong);
  }

  .portrait-frame img {
    display: block;
    width: 100%;
    aspect-ratio: 4 / 5;
    object-fit: cover;
  }

  .portrait-caption {
    position: absolute;
    left: 1.2rem;
    right: 1.2rem;
    bottom: 1.2rem;
    padding: 1rem 1.1rem;
    border-radius: 20px;
    background: rgba(11, 28, 45, 0.78);
    color: #fff;
    backdrop-filter: blur(12px);
  }

  .portrait-caption span {
    display: block;
    color: var(--color-accent-soft);
    font-size: 0.76rem;
    font-weight: 800;
    letter-spacing: 0.14em;
    text-transform: uppercase;
  }

  .portrait-caption strong {
    display: block;
    margin-top: 0.45rem;
    font-size: 1rem;
    line-height: 1.4;
  }

  @media (max-width: 960px) {
    .profesor-grid {
      grid-template-columns: 1fr;
    }
  }

  @media (max-width: 720px) {
    .credentials {
      grid-template-columns: 1fr;
    }
  }
</style>
