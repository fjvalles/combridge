---
const videoTestimonials = [
  {
    video: "/videos/testimonio-jose.mp4",
    author: "José Alejandro Soto",
    role: "Administrador de Contratos BHP - Buffer",
    company: "Minería",
  },
  {
    video: "/videos/testimonio-soledad.mp4",
    author: "Soledad Bernat",
    role: "Jefa Sostenibilidad - Supermercados Cencosud",
    company: "Servicios",
  },
  {
    video: "/videos/testimonio-gabriela.mp4",
    author: "Gabriela Ledezma",
    role: "Especialista Control de Riesgos - Codelco",
    company: "Walmart Chile",
  },
];
---

<section
  class="section prueba"
  id="confianza"
  aria-label="Testimonios de participantes"
>
  <div class="shell">
    <div class="prueba-head reveal">
      <span class="eyebrow">Confían en nosotros</span>
      <h2 class="section-title">Resultados que se ven y se escuchan.</h2>
      <p class="prueba-sub">
        Líderes y equipos comparten su experiencia transformadora tras construir
        el puente.
      </p>
    </div>

    <div class="carousel-wrapper reveal">
      <div class="carousel-container">
        <div class="carousel-track" id="videoTrack">
          {
            videoTestimonials.map((t, index) => (
              <div class="video-slide" data-index={index}>
                <div class="video-card">
                  <div class="video-container">
                    <video
                      controls
                      preload="metadata"
                      class="testimonial-video"
                    >
                      <source src={t.video} type="video/mp4" />
                      Tu navegador no soporta videos.
                    </video>
                  </div>
                  <div class="video-info">
                    <div class="quote-icon" aria-hidden="true">
                      “
                    </div>
                    <div class="author-meta">
                      <strong>{t.author}</strong>
                      <span>
                        {t.role} · {t.company}
                      </span>
                    </div>
                  </div>
                </div>
              </div>
            ))
          }
        </div>
      </div>

      <div class="carousel-dots" id="videoDots">
        {
          videoTestimonials.map((_, index) => (
            <button
              class={`dot ${index === 0 ? "active" : ""}`}
              data-index={index}
              aria-label={`Ver testimonio de ${videoTestimonials[index].author}`}
            />
          ))
        }
      </div>
    </div>
  </div>
</section>

<script>
  const track = document.getElementById("videoTrack");
  const dots = document.querySelectorAll("#videoDots .dot");
  const slides = document.querySelectorAll(".video-slide");
  let currentIndex = 0;
  let intervalId;
  let isVideoPlaying = false;

  function updateCarousel(index) {
    currentIndex = index;
    const offset = -currentIndex * 100;
    if (track) {
      track.style.transform = `translateX(${offset}%)`;
    }

    dots.forEach((dot, i) => {
      dot.classList.toggle("active", i === currentIndex);
    });
  }

  function nextSlide() {
    if (isVideoPlaying) return; // No rotar si hay un video reproduciéndose
    let next = (currentIndex + 1) % slides.length;
    updateCarousel(next);
  }

  function startAutoPlay() {
    stopAutoPlay();
    intervalId = setInterval(nextSlide, 5000);
  }

  function stopAutoPlay() {
    if (intervalId) clearInterval(intervalId);
  }

  dots.forEach((dot, i) => {
    dot.addEventListener("click", () => {
      updateCarousel(i);
      startAutoPlay();
    });
  });

  // Pausar autoplay cuando un video empieza a reproducirse
  document.querySelectorAll(".testimonial-video").forEach((video) => {
    video.addEventListener("play", () => {
      isVideoPlaying = true;
      stopAutoPlay();
    });
    video.addEventListener("pause", () => {
      isVideoPlaying = false;
      startAutoPlay();
    });
    video.addEventListener("ended", () => {
      isVideoPlaying = false;
      startAutoPlay();
    });
  });

  const observer = new IntersectionObserver(
    (entries) => {
      entries.forEach((entry) => {
        if (entry.isIntersecting) {
          entry.target.classList.add("visible");
          if (entry.target.classList.contains("carousel-wrapper")) {
            startAutoPlay();
          }
        }
      });
    },
    { threshold: 0.15 },
  );

  document
    .querySelectorAll(".prueba .reveal")
    .forEach((el) => observer.observe(el));
</script>

<style>
  .prueba {
    padding: 6rem 0;
    background: linear-gradient(
      180deg,
      rgba(255, 255, 255, 0.34) 0%,
      rgba(246, 239, 231, 0.5) 100%
    );
  }

  .prueba-head {
    text-align: center;
    max-width: 42rem;
    margin: 0 auto 3.5rem;
  }

  .prueba .section-title {
    margin: 0.75rem 0 1.25rem;
    font-size: clamp(2rem, 4.5vw, 2.8rem);
    line-height: 1.1;
  }

  .carousel-wrapper {
    position: relative;
    max-width: 54rem;
    margin: 0 auto;
  }

  .carousel-container {
    overflow: hidden;
    border-radius: 28px;
    box-shadow: 0 40px 80px rgba(0, 0, 0, 0.12);
    background: #000;
  }

  .carousel-track {
    display: flex;
    transition: transform 0.8s cubic-bezier(0.45, 0, 0.15, 1);
  }

  .video-slide {
    flex: 0 0 100%;
    min-width: 100%;
  }

  .video-card {
    background: #fff;
    overflow: hidden;
  }

  .video-container {
    position: relative;
    aspect-ratio: 16 / 9;
    background: #000;
    display: flex;
    align-items: center;
    justify-content: center;
  }

  .testimonial-video {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
  }

  .video-info {
    padding: 2rem;
    position: relative;
    text-align: center;
  }

  .quote-icon {
    position: absolute;
    top: -0.5rem;
    right: 2rem;
    font-family: var(--font-display);
    font-size: 4rem;
    line-height: 1;
    color: rgba(217, 109, 63, 0.12);
  }

  .author-meta strong {
    display: block;
    font-size: 1.25rem;
    color: var(--color-text);
    font-weight: 700;
  }

  .author-meta span {
    display: block;
    margin-top: 0.5rem;
    font-size: 0.95rem;
    color: var(--color-text-soft);
  }

  .carousel-dots {
    display: flex;
    justify-content: center;
    gap: 0.75rem;
    margin-top: 2rem;
  }

  .dot {
    width: 10px;
    height: 10px;
    border-radius: 50%;
    background-color: var(--color-line);
    border: none;
    cursor: pointer;
    transition: all 0.3s ease;
    padding: 0;
  }

  .dot.active {
    background-color: var(--color-accent);
    transform: scale(1.3);
  }

  @media (max-width: 640px) {
    .prueba {
      padding: 4rem 0;
    }
    .carousel-wrapper {
      max-width: 100%;
    }
    .video-container {
      aspect-ratio: 4 / 5;
    }
  }
</style>
