---
import { Target, Users, MessageCircle, Trophy } from '@lucide/astro';

const cards = [
  {
    Icon: Target,
    titulo: 'Objetivos claros',
    desc: 'Definir y lograr objetivos concretos en un contexto de trabajo en equipo bajo presión real.',
  },
  {
    Icon: Users,
    titulo: 'Colaborar',
    desc: 'Compartir recursos, asignar tareas y mantener alta calidad colaborando entre subequipos.',
  },
  {
    Icon: MessageCircle,
    titulo: 'Comunicación',
    desc: 'Comunicarse efectivamente y con frecuencia para coordinar esfuerzos sin perder el foco.',
  },
  {
    Icon: Trophy,
    titulo: 'Lograr lo imposible',
    desc: 'Alinear esfuerzos individuales, de equipo y organizacionales para conseguir resultados extraordinarios.',
  },
];
---

<section class="aprendizajes" id="aprendizajes">
  <div class="aprendizajes-inner">
    <div class="header fade-in">
      <span class="eyebrow">Aprendizajes clave</span>
      <h2 class="titulo">Lo que tu equipo se lleva del taller</h2>
    </div>

    <div class="cards-grid">
      {cards.map((card, i) => (
        <article
          class="card fade-in"
          style={`transition-delay: ${i * 100}ms`}
        >
          <div class="card-icon">
            <card.Icon size={32} color="#3E5C76" aria-hidden="true" />
          </div>
          <h3 class="card-titulo">{card.titulo}</h3>
          <p class="card-desc">{card.desc}</p>
        </article>
      ))}
    </div>
  </div>
</section>

<script>
  const observer = new IntersectionObserver(
    (entries) => {
      entries.forEach((entry) => {
        if (entry.isIntersecting) {
          entry.target.classList.add('visible');
          observer.unobserve(entry.target);
        }
      });
    },
    { threshold: 0.12 }
  );

  document.querySelectorAll('#aprendizajes .fade-in').forEach((el) => observer.observe(el));
</script>

<style>
  .aprendizajes {
    background-color: #f8fafc;
    padding: 5rem 1.5rem;
  }

  .aprendizajes-inner {
    max-width: 1100px;
    margin: 0 auto;
  }

  /* ── Header ── */
  .header {
    text-align: center;
    margin-bottom: 3rem;
  }

  .eyebrow {
    display: block;
    font-size: 0.78rem;
    font-weight: 700;
    letter-spacing: 0.14em;
    text-transform: uppercase;
    color: #e63946;
    margin-bottom: 0.75rem;
  }

  .titulo {
    font-size: clamp(1.5rem, 3.5vw, 2.1rem);
    font-weight: 800;
    color: #1f2937;
    line-height: 1.2;
  }

  /* ── Grid ── */
  .cards-grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: 1.25rem;
  }

  @media (min-width: 600px) {
    .cards-grid {
      grid-template-columns: repeat(2, 1fr);
    }
  }

  @media (min-width: 960px) {
    .cards-grid {
      grid-template-columns: repeat(4, 1fr);
    }
  }

  /* ── Card ── */
  .card {
    background: #ffffff;
    border: 1px solid #e2e8f0;
    border-top: 3px solid transparent;
    border-radius: 12px;
    padding: 1.75rem 1.5rem;
    box-shadow: 0 1px 4px rgba(0, 0, 0, 0.06);
    display: flex;
    flex-direction: column;
    gap: 0.75rem;
    transition: transform 0.2s ease, box-shadow 0.2s ease, border-top-color 0.2s ease;
  }

  .card:hover {
    transform: translateY(-4px);
    box-shadow: 0 8px 24px rgba(0, 0, 0, 0.1);
    border-top-color: #3e5c76;
  }

  .card-icon {
    display: flex;
    align-items: center;
  }

  .card-titulo {
    font-size: 1.05rem;
    font-weight: 700;
    color: #1f2937;
    line-height: 1.3;
  }

  .card-desc {
    font-size: 0.9rem;
    color: #64748b;
    line-height: 1.65;
  }

  /* ── Fade-in staggered ── */
  .fade-in {
    opacity: 0;
    transform: translateY(20px);
    transition:
      opacity 0.5s ease,
      transform 0.5s ease;
  }

  .fade-in.visible {
    opacity: 1;
    transform: translateY(0);
  }
</style>
